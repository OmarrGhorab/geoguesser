{
  "countryCodes": [
    "*"
  ],
  "namedExpressions": {
    "$$coastal": "ClosestCoast lt 1500",
    "$$water": "ClosestLake lt 1000 or ClosestRiver lt 1000",
    "$$unpaved": "Surface in ['gravel', 'sand', 'dirt', 'earth', 'fine_gravel', 'ground']",
    "$$rural": "Roads200 lte 2 and Buildings200 lte 4",
    "$$town": "Buildings100 gte 2 and Buildings200 lte 50",
    "$$intersection": "Roads25 gte 3",
    "$$elevated": "Elevation gt 700"
  },
  "distributionStrategy": {
    "key": "FixedCountByMaxMinDistance",
    "locationCountGoal": 45000,
    "minMinDistance": 200
  },
  "globalLocationFilter": "",
  "globalLocationPreferenceFilters": [
    {
      "expression": "$$coastal",
      "percentage": 10,
      "fill": false,
      "locationTag": "coastal"
    },
    {
      "expression": "$$water and $$coastal eq false",
      "percentage": 10,
      "fill": false,
      "locationTag": "water"
    },
    {
      "expression": "$$unpaved",
      "percentage": 10,
      "fill": false,
      "locationTag": "unpaved"
    },
    {
      "expression": "$$rural and $$unpaved eq false",
      "percentage": 10,
      "fill": false,
      "locationTag": "rural"
    },
    {
      "expression": "$$town",
      "percentage": 10,
      "fill": false,
      "locationTag": "town"
    },
    {
      "expression": "$$intersection",
      "percentage": 10,
      "fill": false,
      "locationTag": "intersection"
    },
    {
      "expression": "$$elevated and $$coastal eq false",
      "percentage": 10,
      "fill": false,
      "locationTag": "elevated"
    },
    {
      "expression": "*",
      "percentage": null,
      "fill": true,
      "locationTag": "fill"
    }
  ],
  "output": {
    "globalHeadingExpression": "DrivingDirectionAngle",
    "panoVerificationStrategy": "Newest",
    "locationTags": [
      "CountryCode",
      "SubdivisionCode",
      "Year",
      "Surface",
      "Elevation-100",
      "ClosestCoast-100",
      "ClosestLake-100",
      "ClosestRiver-100",
      "Roads25",
      "Buildings100"
    ]
  }
}