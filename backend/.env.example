APP_ENV=development
VERSION=0.1.0
HTTP_ADDR=:8080
ALLOWED_ORIGIN=http://localhost:3000
METRICS_AUTH_TOKEN=

# Local Docker Compose
DATABASE_URL=postgres://geoguess:geoguess@localhost:5432/geoguess?sslmode=disable
REDIS_URL=redis://localhost:6379/0

# Cloud providers (Neon + Upstash)
# DATABASE_URL=postgresql://<user>:<password>@<neon-host>/<db>?sslmode=require
# REDIS_URL=rediss://default:<password>@<upstash-host>:6379

HTTP_READ_TIMEOUT_SECONDS=10
HTTP_WRITE_TIMEOUT_SECONDS=15
HTTP_IDLE_TIMEOUT_SECONDS=60

# Auth
ACCESS_TOKEN_SECRET=change-me-in-production-access-token-secret-min-32-chars
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_SECRET=change-me-in-production-refresh-token-secret-min-32-chars
REFRESH_TOKEN_TTL_SECONDS=604800
CSRF_SECRET=change-me-in-production-csrf-secret-min-32-chars
GUEST_SESSION_SECRET=change-me-in-production-guest-secret-min-32-chars
COOKIE_DOMAIN=
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# OAuth providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/api/v1/auth/oauth/google/callback
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URL=http://localhost:8080/api/v1/auth/oauth/discord/callback
OAUTH_STATE_TTL_SECONDS=600

# Email / OTP
EMAIL_PROVIDER=logger
EMAIL_FROM=noreply@geoguess.local
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
OTP_TTL_SECONDS=600
OTP_MAX_ATTEMPTS=3
OTP_RATE_LIMIT=3

# Cloudflare R2 (S3-compatible)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://pub-<hash>.r2.dev
R2_SIGNED_URL_TTL_SECONDS=900
R2_MAX_FILE_SIZE_BYTES=10485760
